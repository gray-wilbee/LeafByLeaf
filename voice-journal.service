[Unit]
Description=Voice Journal — audio transcription and AI journaling
After=network.target

[Service]
User=will
WorkingDirectory=/home/will/apps/voice-journal
ExecStart=/home/will/apps/voice-journal/venv/bin/gunicorn -w 1 -b 0.0.0.0:8003 --timeout 120 app:app
Restart=on-failure
RestartSec=5

EnvironmentFile=/home/will/.env/voice-journal

[Install]
WantedBy=multi-user.target
